name = "diag_system_report"
type = "Diag"
category = "adtCategory"
icon = "diag-system-report"
report_suffix = "tar.xz"
display_name.en = "System Report"
display_name.ru = "Отчет System Report"
comment.en = "The tool collects information about the operating system and the computer using the system-report utility.<br>Software information:<ul> <li>OS version</li> <li>Installed packages</li> <li>Network settings</li> </ul> Hardware information: <ul> <li>Storage devices</li><li>Network interfaces</li> <li>Kernel and kernel modules</li> <li>Kernel logs</li> </ul> This tool does not include a test suite. To use it, simply generate a report."
comment.ru = "Инструмент собирает информацию об операционной системе и компьютере через утилиту system-report.<br>Сведения о программном обеспечении: <ul><li>Версия ОС</li><li>Установленные пакеты</li><li>Сетевые параметры</li></ul>Сведения об аппаратном обеспечении:<ul><li>Носители информации</li><li>Сетевые интерфейсы</li><li>Ядро и модули ядра</li><li>Логи ядра</li></ul> В данном инструменте отсутствует набор тестов. Для работы достаточно запустить генерацию отчета."
